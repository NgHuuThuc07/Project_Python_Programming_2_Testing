<mujoco model="car_world">

  <compiler autolimits="true"/>

  <option timestep="0.01" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="2048"/>
    <map zfar="50"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.25 0.25 0.25" rgb2="0.55 0.55 0.55"
             width="512" height="512" mark="none"/>
    <material name="ground_mat" texture="grid"
              texrepeat="10 10" reflectance="0.15"/>
    <material name="car_mat"      rgba="0.15 0.45 0.85 1"/>
    <material name="wheel_mat"    rgba="0.12 0.12 0.12 1"/>
    <material name="obstacle_mat" rgba="0.85 0.18 0.18 1"/>
    <material name="start_mat"    rgba="0.15 0.85 0.15 1"/>
    <material name="goal_mat"     rgba="1.00 0.82 0.00 1"/>
  </asset>

  <worldbody>

    <light name="sun"  pos="0 0 12" dir="0 0 -1"
           diffuse="0.9 0.9 0.9" specular="0.2 0.2 0.2" directional="true"/>
    <light name="fill" pos="8 -8 6" dir="-1 1 -1"
           diffuse="0.3 0.3 0.35" specular="0 0 0"/>

    <geom name="ground" type="plane" size="20 20 0.1"
          material="ground_mat" friction="1.0 0.005 0.0001" condim="3"/>

    <!-- Start marker -->
    <geom name="start_marker" type="cylinder"
          pos="-10 0 0.01" size="0.45 0.01"
          material="start_mat" contype="0" conaffinity="0"/>

    <!-- Goal marker + pole -->
    <geom name="goal_marker" type="cylinder"
          pos="10 0 0.01" size="0.45 0.01"
          material="goal_mat" contype="0" conaffinity="0"/>
    <geom name="goal_pole" type="cylinder"
          pos="10 0 0.6" size="0.04 0.6"
          rgba="1.0 0.82 0.0 1" contype="0" conaffinity="0"/>

    <!-- Obstacles -->
    <geom name="obs1" type="box" pos="-3.0  1.2 0.4" size="0.5 0.5 0.4" material="obstacle_mat"/>
    <geom name="obs2" type="box" pos="-1.0 -1.0 0.4" size="0.5 0.5 0.4" material="obstacle_mat"/>
    <geom name="obs3" type="box" pos=" 2.0  1.5 0.4" size="0.5 0.5 0.4" material="obstacle_mat"/>
    <geom name="obs4" type="box" pos=" 3.0 -0.3 0.4" size="0.5 0.5 0.4" material="obstacle_mat"/>
    <geom name="obs5" type="box" pos=" 0.0  0.0 0.4" size="0.4 0.4 0.4" material="obstacle_mat"/>
     <geom name="wall_1" type="box" pos=" 8.0  0.0 0.4" size="0.5 2.5 0.4" material="obstacle_mat"/>

    <!-- Car -->
    <body name="car" pos="-10 0 0.12">
      <freejoint name="car_freejoint"/>

      <geom name="chassis" type="box" size="0.42 0.22 0.08"
            material="car_mat" mass="1.5" friction="0.01 0.005 0.0001" condim="1"/>
      <geom name="roof" type="box" pos="0 0 0.14" size="0.22 0.18 0.06"
            material="car_mat" mass="0.3" contype="0" conaffinity="0"/>
      <geom name="bumper" type="box" pos="0.44 0 -0.02" size="0.04 0.20 0.05"
            rgba="0.7 0.7 0.7 1" mass="0.1" contype="0" conaffinity="0"/>
      <geom name="light_l" type="sphere" pos="0.43  0.14 0.02" size="0.04"
            rgba="1.0 0.95 0.6 1" contype="0" conaffinity="0"/>
      <geom name="light_r" type="sphere" pos="0.43 -0.14 0.02" size="0.04"
            rgba="1.0 0.95 0.6 1" contype="0" conaffinity="0"/>
      <geom name="wfl" type="sphere" pos=" 0.28  0.19 -0.06" size="0.09"
            euler="1.5708 0 0" material="wheel_mat" mass="0.2" contype="0" conaffinity="0"/>
      <geom name="wfr" type="sphere" pos=" 0.28 -0.19 -0.06" size="0.09"
            euler="1.5708 0 0" material="wheel_mat" mass="0.2" contype="0" conaffinity="0"/>
      <geom name="wrl" type="sphere" pos="-0.28  0.19 -0.06" size="0.09"
            euler="1.5708 0 0" material="wheel_mat" mass="0.2" contype="0" conaffinity="0"/>
      <geom name="wrr" type="sphere" pos="-0.28 -0.19 -0.06" size="0.09"
            euler="1.5708 0 0" material="wheel_mat" mass="0.2" contype="0" conaffinity="0"/>
      <geom name="sensor_dot" type="sphere" pos="0.46 0 0.08" size="0.04"
            rgba="0 1 0 1" contype="0" conaffinity="0"/>

      <inertial pos="0 0 0" mass="2.5" diaginertia="0.12 0.22 0.30"/>
    </body>

  </worldbody>

  <sensor>
    <framepos   name="car_pos"   objtype="body" objname="car"/>
    <framexaxis name="car_xaxis" objtype="body" objname="car"/>
  </sensor>

</mujoco>
